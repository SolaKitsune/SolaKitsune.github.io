@charset "UTF-8";@import "https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&display=swap";body{background-color:#f0f5fa;color:#1a2b3c;font-family:noto serif sc,pingfang sc,microsoft yahei,serif;line-height:1.7;transition:all .3s ease}.book-page{background-color:rgba(255,255,255,.7);backdrop-filter:blur(4px);border-radius:12px;padding:2rem;max-width:40rem;margin:0 auto;box-shadow:0 4px 20px rgba(0,30,60,.1)}.book-page p{font-size:1.125rem;line-height:1.8;margin-bottom:1.5rem}a{color:#06a;border-bottom:1px solid transparent;transition:all .2s}a:hover{color:#08d;border-bottom-color:#08d}.book-menu .menu-item-has-children>a::after{content:'▾';float:right;transition:transform .2s}.book-menu .menu-item-has-children.active>a::after{transform:rotate(-180deg)}.book-menu .menu-item-has-children ul{display:none;padding-left:1rem;border-left:1px solid rgba(0,100,200,.2)}.book-menu .menu-item-has-children.active ul{display:block}@media(prefers-color-scheme:dark){body{background-color:#0a1420;color:#c0d0e0}.book-page{background-color:rgba(20,30,40,.8);box-shadow:0 4px 20px rgba(0,200,255,.1)}a{color:#60b0ff}}